# I load secrets from $ORION_OVERLAY_ROOT/config/.env when present. Never commit .env.

# Claude API key for LangGraph Planner/Coder (code development only)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Local MySQL (dev-only; not production MCP database)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=orion
MYSQL_PASSWORD=CHANGE_ME_ORION_LOCAL
MYSQL_DATABASE=orion_app

# LangSmith tracing for RAG index / retrieve / eval (optional)
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=orion-rag
# ORION_RAG_TRACING=false
# ORION_RAG_HYBRID=1
